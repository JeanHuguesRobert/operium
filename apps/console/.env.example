# Dev: leave base URL empty to use same-origin + vite proxy (/ops → fracta)
VITE_COGENTIA_OPS_BASE_URL=

# Build-time token for authenticated /ops/node/* proxy routes (never commit real values)
VITE_COGENTIA_OPS_TOKEN=

# Production asset base when hosted on fracta
VITE_CONSOLE_BASE=/ops/console/

# Optional dev overrides
# VITE_DEV_OPS_PROXY=https://cogentia.fractavolta.com
# VITE_CONSOLE_PORT=5174